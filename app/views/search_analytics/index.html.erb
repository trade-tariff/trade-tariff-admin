<% content_for :page_title, "Search dashboard" %>

<% summary = (@search_analytics.summary || {}).with_indifferent_access %>
<% statuses = (@search_analytics.summary_statuses || {}).with_indifferent_access %>
<% trends = (@search_analytics.trends || {}).with_indifferent_access %>
<% comparisons = (@search_analytics.comparisons || {}).with_indifferent_access %>
<% request_sources = (@search_analytics.request_sources || {}).with_indifferent_access %>
<% ai_costs = (@search_analytics.ai_costs || {}).with_indifferent_access %>
<% ai_cost_summary = (ai_costs[:summary] || {}).with_indifferent_access %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h1 class="govuk-heading-l">Search dashboard</h1>
    <% if @search_analytics.generated_at.present? %>
      <p class="govuk-body-s govuk-!-margin-bottom-5">
        Generated <%= search_analytics_timestamp(@search_analytics.generated_at) %>.
      </p>
    <% end %>

    <div class="search-analytics-filters govuk-!-margin-bottom-5">
      <div>
        <h2 class="govuk-heading-s govuk-!-margin-bottom-2">Period</h2>
        <div class="govuk-button-group">
          <% [["24h", "24 hours"], ["7d", "7 days"], ["30d", "30 days"]].each do |period, label| %>
            <%= link_to label,
                        search_analytics_path(period: period, view: @view),
                        class: ["govuk-link", ("govuk-!-font-weight-bold" if @period == period)].compact.join(" ") %>
          <% end %>
        </div>
      </div>
      <div>
        <h2 class="govuk-heading-s govuk-!-margin-bottom-2">View</h2>
        <div class="govuk-button-group">
          <% [["all", "All"], ["classic", "Classic"], ["internal", "Internal"]].each do |view, label| %>
            <%= link_to label,
                        search_analytics_path(period: @period, view: view),
                        class: ["govuk-link", ("govuk-!-font-weight-bold" if @view == view)].compact.join(" ") %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="search-analytics-metrics">
      <% [
        ["Searches", search_analytics_number(summary[:searches]), statuses[:searches]],
        ["Failure rate", search_analytics_percentage(summary[:failure_rate]), statuses[:failure_rate]],
        ["Zero-result rate", search_analytics_percentage(summary[:zero_result_rate]), statuses[:zero_result_rate]],
        ["Selection rate", search_analytics_percentage(summary[:selection_rate]), statuses[:selection_rate]],
        ["P90 latency", search_analytics_latency(summary[:p90_latency_ms]), statuses[:p90_latency_ms]],
      ].each do |label, value, status| %>
        <% status = (status || {}).with_indifferent_access %>
        <section class="search-analytics-metric" aria-label="<%= label %>">
          <h2 class="govuk-heading-s"><%= label %></h2>
          <p class="search-analytics-metric__value"><%= value %></p>
          <% if status[:level].present? %>
            <%= govuk_tag(text: status[:level].to_s.humanize, colour: search_analytics_status_tag_colour(status[:level])) %>
          <% end %>
          <% if status[:message].present? %>
            <p class="govuk-body-s govuk-!-margin-top-2"><%= status[:message] %></p>
          <% end %>
        </section>
      <% end %>
    </div>

    <%= render GovukComponent::DetailsComponent.new(summary_text: "How these metrics are calculated", classes: "govuk-!-margin-top-4") do %>
      <%= govuk_summary_list(
            borders: false,
            classes: "search-analytics-metric-definitions",
            rows: [
              {
                key: { text: "Searches" },
                value: { text: "Completed and failed search requests for the selected period and view." },
              },
              {
                key: { text: "Failure rate" },
                value: { text: "Failed searches divided by all searches." },
              },
              {
                key: { text: "Zero-result rate" },
                value: { text: "Completed searches with no results divided by completed searches." },
              },
              {
                key: { text: "Selection rate" },
                value: { text: "Result selections divided by eligible searches. Eligible searches are classic fuzzy searches and internal searches that return ranked confidence results. Can exceed 100% when users open more than one result." },
              },
              {
                key: { text: "P90 latency" },
                value: { text: "The response time that 90% of completed and failed searches were faster than." },
              },
            ],
          ) %>
    <% end %>

    <section class="search-analytics-ai-cost govuk-!-margin-top-7" aria-labelledby="ai-cost-heading">
      <h2 id="ai-cost-heading" class="govuk-heading-l govuk-!-margin-bottom-3">AI cost</h2>
      <p class="govuk-body">Estimated OpenAI cost in US dollars for AI-assisted searches in this period. Cached input is included at its discounted price.</p>

      <% if @view == "classic" %>
        <%= govuk_inset_text do %>
          Classic search does not make AI model or embedding calls, so there is no AI cost for this view.
        <% end %>
      <% elsif ai_cost_summary[:assisted_searches].to_i.zero? %>
        <%= govuk_inset_text do %>
          No AI-assisted searches with cost diagnostics were recorded for this period and view.
        <% end %>
      <% else %>
        <div class="search-analytics-metrics search-analytics-ai-cost__metrics govuk-!-margin-top-5">
          <% [
            [ai_cost_summary[:complete] ? "Estimated total cost" : "Known AI cost", search_analytics_cost(ai_cost_summary[:total_cost_usd])],
            ["AI-assisted searches", search_analytics_number(ai_cost_summary[:assisted_searches])],
            ["Average cost per search", search_analytics_cost(ai_cost_summary[:average_cost_usd])],
            ["P90 cost per search", search_analytics_cost(ai_cost_summary[:p90_cost_usd])],
          ].each do |label, value| %>
            <section class="search-analytics-metric" aria-label="<%= label %>">
              <h3 class="govuk-heading-s"><%= label %></h3>
              <p class="search-analytics-metric__value"><%= value %></p>
            </section>
          <% end %>
        </div>

        <% if ai_cost_summary[:complete] %>
          <p class="govuk-body-s govuk-!-margin-top-3">Pricing coverage: <%= search_analytics_percentage(ai_cost_summary[:pricing_coverage]) %> of token-bearing AI calls.</p>
        <% else %>
          <%= govuk_inset_text(classes: "govuk-!-margin-top-4") do %>
            <strong>Known cost only.</strong> Pricing was available for <%= search_analytics_percentage(ai_cost_summary[:pricing_coverage]) %> of token-bearing AI calls. Calls without configured pricing are excluded from the cost figures.
          <% end %>
        <% end %>

        <% ai_cost_trend = Array(ai_costs[:trend]) %>
        <% if ai_cost_trend.any? %>
          <section class="search-analytics-ai-cost__chart govuk-!-margin-top-6" aria-labelledby="ai-cost-trend-heading">
            <h3 id="ai-cost-trend-heading" class="govuk-heading-m">Cost over time</h3>
            <div class="search-analytics-chart-container">
              <canvas class="search-analytics-chart"
                      role="img"
                      aria-label="Stacked AI cost over time split into model input, model output and embeddings"
                      data-chart-type="bar"
                      data-stacked="true"
                      data-y-axis-format="currency"
                      data-chart="<%= search_analytics_cost_chart_payload(ai_cost_trend) %>">
                AI cost over time. Use the data table below for exact values.
              </canvas>
            </div>

            <%= render GovukComponent::DetailsComponent.new(summary_text: "View AI cost chart data", classes: "govuk-!-margin-top-3") do %>
              <table class="govuk-table">
                <thead class="govuk-table__head">
                  <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">Time</th>
                    <th scope="col" class="govuk-table__header govuk-table__header--numeric">Model input</th>
                    <th scope="col" class="govuk-table__header govuk-table__header--numeric">Model output</th>
                    <th scope="col" class="govuk-table__header govuk-table__header--numeric">Embeddings</th>
                    <th scope="col" class="govuk-table__header govuk-table__header--numeric">Total</th>
                  </tr>
                </thead>
                <tbody class="govuk-table__body">
                  <% ai_cost_trend.each do |row| %>
                    <% row = row.with_indifferent_access %>
                    <tr class="govuk-table__row">
                      <th scope="row" class="govuk-table__header"><%= search_analytics_timestamp(row[:bucket]) %></th>
                      <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_cost(row[:input_cost_usd]) %></td>
                      <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_cost(row[:output_cost_usd]) %></td>
                      <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_cost(row[:embedding_cost_usd]) %></td>
                      <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_cost(row[:total_cost_usd]) %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
          </section>
        <% end %>

        <% operation_rows = search_analytics_ai_operation_rows(ai_costs[:operations], total_cost: ai_cost_summary[:total_cost_usd]) %>
        <% if operation_rows.any? %>
          <section class="search-analytics-ai-cost__breakdown govuk-!-margin-top-6" aria-labelledby="ai-cost-breakdown-heading">
            <h3 id="ai-cost-breakdown-heading" class="govuk-heading-m">Cost by operation</h3>
            <table class="govuk-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Operation</th>
                  <th scope="col" class="govuk-table__header govuk-table__header--numeric">Calls</th>
                  <th scope="col" class="govuk-table__header govuk-table__header--numeric">Tokens</th>
                  <th scope="col" class="govuk-table__header govuk-table__header--numeric">Cost</th>
                  <th scope="col" class="govuk-table__header govuk-table__header--numeric">Share</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                <% operation_rows.each do |row| %>
                  <tr class="govuk-table__row">
                    <th scope="row" class="govuk-table__header"><%= row[:label] %></th>
                    <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_number(row[:calls]) %></td>
                    <td class="govuk-table__cell govuk-table__cell--numeric">
                      <%= search_analytics_number(row[:total_tokens]) %>
                      <span class="search-analytics-table-detail"><%= search_analytics_number(row[:input_tokens]) %> input · <%= search_analytics_number(row[:cached_input_tokens]) %> cached · <%= search_analytics_number(row[:output_tokens]) %> output</span>
                    </td>
                    <td class="govuk-table__cell govuk-table__cell--numeric">
                      <strong><%= search_analytics_cost(row[:total_cost_usd]) %> total</strong>
                      <span class="search-analytics-table-detail"><%= search_analytics_cost(row[:input_cost_usd]) %> input · <%= search_analytics_cost(row[:output_cost_usd]) %> output · <%= search_analytics_cost(row[:embedding_cost_usd]) %> embeddings</span>
                    </td>
                    <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_percentage(row[:share]) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </section>
        <% end %>
      <% end %>
    </section>

    <div class="search-analytics-charts govuk-!-margin-top-6">
      <section>
        <h2 class="govuk-heading-m">Volume by view</h2>
        <div class="search-analytics-chart-container">
          <canvas class="search-analytics-chart"
                  data-chart="<%= search_analytics_chart_payload(trends[:volume], series: { all: "All", classic: "Classic", internal: "Internal" }, minimum_series_share: 1) %>"></canvas>
        </div>
      </section>

      <section>
        <h2 class="govuk-heading-m">Volume by request source</h2>
        <div class="search-analytics-chart-container">
          <canvas class="search-analytics-chart"
                  data-chart="<%= search_analytics_chart_payload(trends[:volume], series: { frontend: "Frontend-routed", backend_only: "Direct backend / non-frontend", unknown: "Unknown" }, minimum_series_share: 1) %>"></canvas>
        </div>
      </section>

      <section>
        <h2 class="govuk-heading-m">Outcome trend</h2>
        <div class="search-analytics-chart-container">
          <canvas class="search-analytics-chart"
                  data-chart="<%= search_analytics_chart_payload(trends[:outcomes], series: { completed: "Completed", failed: "Failed", zero_result: "Zero result", selected: "Selected" }, minimum_series_share: 1) %>"></canvas>
        </div>
      </section>
    </div>

    <% if search_analytics_show_view_summary?(comparisons) %>
      <section class="search-analytics-view-summary govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Searches by view</h2>
        <table class="govuk-table search-analytics-view-summary__table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">View</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Searches</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Share</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            <% search_analytics_view_summary_rows(comparisons).each do |row| %>
              <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header"><%= row[:label] %></th>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_number(row[:searches]) %></td>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= row[:percentage] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>
    <% end %>

    <% source_rows = search_analytics_request_source_rows(request_sources) %>
    <% if source_rows.any? %>
      <section class="search-analytics-request-source-summary govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Searches by request source</h2>
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Source</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Searches</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Failure rate</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Zero-result rate</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Selection rate</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">P90 latency</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            <% source_rows.each do |row| %>
              <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header"><%= row[:label] %></th>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_number(row[:searches]) %></td>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_percentage(row[:failure_rate]) %></td>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_percentage(row[:zero_result_rate]) %></td>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_percentage(row[:selection_rate]) %></td>
                <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_latency(row[:p90_latency_ms]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>
    <% end %>

    <section class="govuk-!-margin-top-6" aria-labelledby="zero-search-terms-heading">
      <h2 id="zero-search-terms-heading" class="govuk-heading-m">Zero search terms</h2>
      <div class="search-analytics-term-controls govuk-!-margin-bottom-3">
        <% [["search_terms", "Search terms"], ["item_ids", "Item IDs"]].each do |filter, label| %>
          <%= link_to label,
                      search_analytics_path(period: @period, view: @view, term_filter: filter),
                      class: ["govuk-link", ("govuk-!-font-weight-bold" if @term_filter == filter)].compact.join(" ") %>
        <% end %>
      </div>
      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Query</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">Zero-result searches</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <% @improvement_terms.each do |term| %>
            <% term = term.with_indifferent_access %>
            <tr class="govuk-table__row">
              <td class="govuk-table__cell" data-improvement-term-query><%= term[:query] %></td>
              <td class="govuk-table__cell govuk-table__cell--numeric"><%= search_analytics_number(term[:zero_results]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <%= paginate @improvement_terms, params: { period: @period, view: @view, term_filter: @term_filter } %>
    </section>
  </div>
</div>
