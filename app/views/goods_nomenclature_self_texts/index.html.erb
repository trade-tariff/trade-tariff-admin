<h1 class="govuk-heading-l">Descriptions</h1>

<div class="govuk-tabs" data-module="govuk-tabs">
  <h2 class="govuk-tabs__title">Contents</h2>

  <ul class="govuk-tabs__list">
    <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
      <a class="govuk-tabs__tab" href="#self-texts">Self-texts</a>
    </li>
    <li class="govuk-tabs__list-item">
      <a class="govuk-tabs__tab" href="#labels">Labels</a>
    </li>
  </ul>

  <%# ===== Self-texts tab ===== %>
  <div class="govuk-tabs__panel" id="self-texts">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <%= form_with url: search_goods_nomenclature_self_texts_path, method: :get, local: true do |f| %>
          <div class="govuk-form-group">
            <%= f.label :q, "Search", class: "govuk-label govuk-label--m" %>
            <div class="govuk-hint">
              Search by commodity code (2+ digits), self-text content, or ancestor/sibling descriptions.
            </div>
            <%= f.text_field :q,
                             value: params[:q],
                             class: "govuk-input govuk-input--width-20" %>
          </div>

          <%= f.submit "Search", class: "govuk-button", data: { module: "govuk-button" } %>
        <% end %>
      </div>
    </div>

    <details class="govuk-details">
      <summary class="govuk-details__summary">
        <span class="govuk-details__summary-text">About self-texts</span>
      </summary>
      <div class="govuk-details__text">
        <p class="govuk-body">Self-texts are self-contained descriptions of what each commodity code covers. They go into the search index so traders can find the right code. Non-'Other' nodes get a mechanical description built from their ancestor chain. 'Other' nodes get an AI-generated description that replaces the bare 'Other' with what the code actually covers, using sibling and parent context.</p>

        <h3 class="govuk-heading-s">Tags</h3>
        <ul class="govuk-list govuk-list--bullet">
          <li><strong>Needs review</strong> - an admin has flagged this self-text for review</li>
          <li><strong>Stale</strong> - the commodity's hierarchy has changed since the self-text was generated, so it may no longer be accurate</li>
          <li><strong>Manually edited</strong> - a human has edited the self-text</li>
        </ul>

        <h3 class="govuk-heading-s">Score categories</h3>
        <p class="govuk-body">The score is derived from similarity to the EU reference text and coherence checks. When both are available, they are averaged. A self-text with no score has not yet been compared against the EU reference.</p>
        <ul class="govuk-list govuk-list--bullet">
          <li><strong>Low</strong> - score below 0.3</li>
          <li><strong>Medium</strong> - score 0.3 to 0.5</li>
          <li><strong>High</strong> - score 0.5 to 0.85</li>
          <li><strong>Very High</strong> - score 0.85 or above</li>
        </ul>

        <h3 class="govuk-heading-s">Score and tags are independent</h3>
        <p class="govuk-body">A self-text can have a high score but still need review. The score measures how closely the text matches the EU reference, while the review tag is set manually by admins to mark self-texts that need attention.</p>
      </div>
    </details>

    <h2 class="govuk-heading-m">Self-texts</h2>

    <div class="govuk-grid-row"
         data-controller="generated-content-table"
         data-generated-content-table-url-value="<%= goods_nomenclature_self_texts_path(format: :json) %>"
         data-generated-content-table-show-url-value="<%= goods_nomenclature_self_texts_path %>/__ID__"
         data-generated-content-table-show-id-field-value="goods_nomenclature_sid"
         data-generated-content-table-description-field-value="self_text"
         data-generated-content-table-description-heading-value="Self-text"
         data-generated-content-table-empty-message-value="No self-texts found."
         data-generated-content-table-error-message-value="Failed to load self-texts."
         data-generated-content-table-table-class-value="self-text-table"
         data-generated-content-table-q-value="<%= params[:q] %>">

      <div class="govuk-grid-column-one-quarter">
        <h3 class="govuk-heading-s">Filters</h3>

        <%= render "shared/generated_content_filter_group",
                   legend: "Type",
                   options: generated_content_type_options(:self_text),
                   prefix: "st",
                   input_name: "st_type",
                   action_name: "changeType",
                   data_attribute: "type",
                   default_value: "commodity" %>

        <%= render "shared/generated_content_filter_group",
                   legend: "Score",
                   options: generated_content_score_options,
                   prefix: "st",
                   input_name: "st_score_category",
                   action_name: "changeScoreCategory",
                   data_attribute: "score-category",
                   default_value: "" %>

        <%= render "shared/generated_content_filter_group",
                   legend: "Tags",
                   options: generated_content_tag_options,
                   prefix: "st",
                   input_name: "st_tags",
                   action_name: "changeTags",
                   data_attribute: "status",
                   default_value: "" %>
      </div>

      <div class="govuk-grid-column-three-quarters">
        <p class="govuk-body" data-generated-content-table-target="loading">Loading...</p>
        <div class="self-text-table-container" data-generated-content-table-target="table"></div>
        <div data-generated-content-table-target="pagination"></div>
      </div>
    </div>
  </div>

  <%# ===== Labels tab ===== %>
  <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="labels"
       data-controller="generated-content-table"
       data-generated-content-table-url-value="<%= goods_nomenclature_labels_path(format: :json) %>"
       data-generated-content-table-show-url-value="<%= goods_nomenclature_labels_path %>/__ID__"
       data-generated-content-table-show-id-field-value="goods_nomenclature_item_id"
       data-generated-content-table-description-field-value="description"
       data-generated-content-table-description-heading-value="Description"
       data-generated-content-table-empty-message-value="No labels found."
       data-generated-content-table-error-message-value="Failed to load labels."
       data-generated-content-table-table-class-value="label-table">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="label-search-q">Search</label>
          <div class="govuk-hint">
            Search by commodity code, description, synonyms, or colloquial terms.
          </div>
          <input class="govuk-input govuk-input--width-20" id="label-search-q" type="text"
                 data-generated-content-table-target="searchInput"
                 data-action="keydown.enter->generated-content-table#search">
        </div>
        <button class="govuk-button" data-module="govuk-button"
                data-action="click->generated-content-table#search">Search</button>
      </div>
    </div>

    <details class="govuk-details">
      <summary class="govuk-details__summary">
        <span class="govuk-details__summary-text">About labels</span>
      </summary>
      <div class="govuk-details__text">
        <p class="govuk-body">Labels are AI-generated metadata attached to commodity codes to improve search. They enrich the tariff with additional terms that traders might use when searching. Labels can be reviewed and edited by administrators.</p>

        <h3 class="govuk-heading-s">Label fields</h3>
        <ul class="govuk-list govuk-list--bullet">
          <li><strong>Description</strong> - a rewritten version of the commodity description, simplified for search</li>
          <li><strong>Known brands</strong> - brand names commonly associated with the commodity</li>
          <li><strong>Colloquial terms</strong> - informal or everyday names traders use for the commodity</li>
          <li><strong>Synonyms</strong> - alternative terms with the same meaning as the commodity description</li>
        </ul>

        <h3 class="govuk-heading-s">How labels affect search</h3>
        <p class="govuk-body">Labels feed into the Online Trade Tariff search, helping traders find the correct commodity code. Edits are reflected in search results after reindexing.</p>
      </div>
    </details>

    <h2 class="govuk-heading-m">Labels</h2>

    <div class="govuk-grid-row">

      <div class="govuk-grid-column-one-quarter">
        <h3 class="govuk-heading-s">Filters</h3>

        <%= render "shared/generated_content_filter_group",
                   legend: "Type",
                   options: generated_content_type_options(:label),
                   prefix: "lb",
                   input_name: "lb_type",
                   action_name: "changeType",
                   data_attribute: "type",
                   default_value: "commodity" %>

        <%= render "shared/generated_content_filter_group",
                   legend: "Score",
                   options: generated_content_score_options,
                   prefix: "lb",
                   input_name: "lb_score_category",
                   action_name: "changeScoreCategory",
                   data_attribute: "score-category",
                   default_value: "" %>

        <%= render "shared/generated_content_filter_group",
                   legend: "Tags",
                   options: generated_content_tag_options,
                   prefix: "lb",
                   input_name: "lb_tags",
                   action_name: "changeTags",
                   data_attribute: "status",
                   default_value: "" %>
      </div>

      <div class="govuk-grid-column-three-quarters">
        <p class="govuk-body" data-generated-content-table-target="loading">Loading...</p>
        <div class="label-table-container" data-generated-content-table-target="table"></div>
        <div data-generated-content-table-target="pagination"></div>
      </div>
    </div>
  </div>
</div>
