<h1 class="govuk-heading-l">Recent changes</h1>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-one-quarter">
    <h3 class="govuk-heading-s">Filters</h3>

    <%= form_with url: versions_path, method: :get, local: true do %>
      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Type</legend>
          <div class="govuk-radios govuk-radios--small">
            <% [
              ["All", ""],
              ["Labels", "GoodsNomenclatureLabel"],
              ["Self-texts", "GoodsNomenclatureSelfText"],
              ["Search references", "SearchReference"],
              ["Configurations", "AdminConfiguration"],
            ].each do |label, value| %>
              <div class="govuk-radios__item">
                <input class="govuk-radios__input"
                       id="type-<%= label.parameterize %>"
                       name="item_type"
                       type="radio"
                       value="<%= value %>"
                       <%= "checked" if params[:item_type].to_s == value %>
                       onchange="this.form.submit()">
                <label class="govuk-label govuk-radios__label" for="type-<%= label.parameterize %>"><%= label %></label>
              </div>
            <% end %>
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Event</legend>
          <div class="govuk-radios govuk-radios--small">
            <% [
              ["Updates", "update"],
              ["Creates", "create"],
              ["Deletions", "destroy"],
              ["All events", ""],
            ].each do |label, value| %>
              <div class="govuk-radios__item">
                <input class="govuk-radios__input"
                       id="event-<%= label.parameterize %>"
                       name="event"
                       type="radio"
                       value="<%= value %>"
                       <%= "checked" if event_filter == value %>
                       onchange="this.form.submit()">
                <label class="govuk-label govuk-radios__label" for="event-<%= label.parameterize %>"><%= label %></label>
              </div>
            <% end %>
          </div>
        </fieldset>
      </div>
    <% end %>
  </div>

  <div class="govuk-grid-column-three-quarters">
    <% if @versions.respond_to?(:any?) && @versions.any? %>
      <table class="govuk-table">
        <thead class="govuk-table__header">
          <tr class="govuk-table__row">
            <th class="govuk-table__header" scope="col">Type</th>
            <th class="govuk-table__header" scope="col">Item</th>
            <th class="govuk-table__header" scope="col">Event</th>
            <th class="govuk-table__header" scope="col">Changes</th>
            <th class="govuk-table__header" scope="col">Changed by</th>
            <th class="govuk-table__header" scope="col">Date</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <% @versions.each do |version| %>
            <tr class="govuk-table__row">
              <td class="govuk-table__cell"><%= version.friendly_type_name %></td>
              <td class="govuk-table__cell">
                <% link = version_item_link(version) %>
                <% if link %>
                  <%= link_to version.item_description || version.item_id, link, class: "govuk-link" %>
                <% else %>
                  <%= version.item_description || version.item_id %>
                <% end %>
              </td>
              <td class="govuk-table__cell"><%= version.event.capitalize %></td>
              <td class="govuk-table__cell">
                <% summary = changeset_summary(version) %>
                <% if version.has_changeset? %>
                  <details class="govuk-details govuk-!-margin-bottom-0">
                    <summary class="govuk-details__summary">
                      <span class="govuk-details__summary-text"><%= summary %></span>
                    </summary>
                    <div class="govuk-details__text">
                      <%= changeset_detail_html(version) %>
                    </div>
                  </details>
                <% elsif summary %>
                  <%= summary %>
                <% else %>
                  -
                <% end %>
              </td>
              <td class="govuk-table__cell"><%= version.whodunnit_name || "-" %></td>
              <td class="govuk-table__cell"><%= version.created_at_formatted %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%= paginate @versions %>
    <% else %>
      <p class="govuk-body">No changes found.</p>
    <% end %>
  </div>
</div>
